{
  "name": "ongkirhub",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @ongkirhub/api dev",
    "test": "pnpm build && pnpm -r --sequential run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "esbuild": "^0.25.0",
    "pnpm": "9.15.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@testing-library/react": "16.0.0",
    "@types/google.maps": "^3.58.0",
    "@types/node": "^22.13.4",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "jsdom": "26.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "vite": "^6.0.0"
  }
}
