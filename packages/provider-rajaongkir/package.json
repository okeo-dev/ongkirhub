{
  "name": "@ongkirhub/provider-rajaongkir",
  "version": "0.1.1-alpha.0",
  "description": "RajaOngkir shipping provider for OngkirHub",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/location/generated"
  ],
  "scripts": {
    "compile:locations": "node --import tsx src/location/compile.ts",
    "build": "pnpm run compile:locations && tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ongkirhub/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "yaml": "^2.7.0"
  }
}
