{
  "name": "@ongkirhub/widget",
  "version": "0.1.0",
  "description": "Embeddable vanilla-JS shipping calculator widget for OngkirHub",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bundle"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-browser.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist bundle"
  },
  "dependencies": {
    "@ongkirhub/client": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
