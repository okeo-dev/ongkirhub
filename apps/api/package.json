{
  "name": "@ongkirhub/api",
  "version": "0.1.0",
  "description": "HTTP API for OngkirHub shipping quotes",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@ongkirhub/core": "workspace:*",
    "@ongkirhub/provider-manual": "workspace:*",
    "@ongkirhub/provider-mock": "workspace:*",
    "@ongkirhub/provider-biteship": "workspace:*",
    "@ongkirhub/provider-rajaongkir": "workspace:*",
    "@ongkirhub/runtime": "workspace:*",
    "hono": "^4.7.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
